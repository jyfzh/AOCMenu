<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="aoc.UI.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:vm="using:aoc.UI.ViewModels"
    xmlns:conv="using:aoc.UI.Converters"
    mc:Ignorable="d">

    <Page.Resources>
        <!-- Converters -->
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <conv:BooleanToOpacityConverter x:Key="BooleanToOpacityConverter" />

        <!-- ── Template: Enum-backed settings (ComboBox) ── -->
        <DataTemplate x:Key="EnumSettingTemplate" x:DataType="vm:SettingViewModel">
            <controls:SettingsCard
                Header="{x:Bind DisplayName}"
                IsEnabled="{x:Bind IsEnabled, Mode=OneWay}"
                Opacity="{x:Bind IsEnabled, Mode=OneWay, Converter={StaticResource BooleanToOpacityConverter}}"
                Margin="0,0,0,2">
                <ComboBox
                    ItemsSource="{x:Bind DisplayOptions}"
                    SelectedIndex="{x:Bind SelectedIndex, Mode=TwoWay}"
                    PlaceholderText="---"
                    MinWidth="120"
                    HorizontalAlignment="Right" />
            </controls:SettingsCard>
        </DataTemplate>

        <!-- ── Template: Numeric-range settings (Slider) ── -->
        <DataTemplate x:Key="SliderSettingTemplate" x:DataType="vm:SettingViewModel">
            <controls:SettingsCard
                Header="{x:Bind DisplayName}"
                IsEnabled="{x:Bind IsEnabled, Mode=OneWay}"
                Opacity="{x:Bind IsEnabled, Mode=OneWay, Converter={StaticResource BooleanToOpacityConverter}}"
                Margin="0,0,0,2">
                <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                    <Slider
                        Minimum="0"
                        TickFrequency="1"
                        Width="200"
                        VerticalAlignment="Center"
                        Maximum="{x:Bind SliderMax, Mode=OneWay}"
                        Value="{x:Bind SliderValue, Mode=TwoWay}" />
                    <TextBlock
                        Text="{x:Bind SliderValue, Mode=OneWay}"
                        Style="{StaticResource BodyTextBlockStyle}"
                        MinWidth="28"
                        TextAlignment="Center"
                        VerticalAlignment="Center" />
                </StackPanel>
            </controls:SettingsCard>
        </DataTemplate>

        <!-- ── Template: Read-only fallback ── -->
        <DataTemplate x:Key="ReadOnlySettingTemplate" x:DataType="vm:SettingViewModel">
            <controls:SettingsCard
                Header="{x:Bind DisplayName}"
                IsEnabled="{x:Bind IsEnabled, Mode=OneWay}"
                Opacity="{x:Bind IsEnabled, Mode=OneWay, Converter={StaticResource BooleanToOpacityConverter}}"
                Margin="0,0,0,2">
                <TextBlock
                    Text="{x:Bind CurrentValue, Mode=OneWay}"
                    Style="{StaticResource BodyTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    HorizontalAlignment="Right" />
            </controls:SettingsCard>
        </DataTemplate>

        <!-- ── Template Selector ── -->
        <conv:SettingTemplateSelector
            x:Key="SettingTemplateSelector"
            EnumSettingTemplate="{StaticResource EnumSettingTemplate}"
            SliderSettingTemplate="{StaticResource SliderSettingTemplate}"
            ReadOnlySettingTemplate="{StaticResource ReadOnlySettingTemplate}" />

        <!-- ── Template: Single category group ── -->
        <DataTemplate x:Key="CategoryTemplate" x:DataType="vm:CategoryGroup">
            <StackPanel>
                <!-- Category header -->
                <TextBlock
                    Text="{x:Bind Name}"
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    Margin="0,16,0,8" />

                <!-- Settings inside this category -->
                <ItemsRepeater
                    ItemsSource="{x:Bind Settings}"
                    ItemTemplate="{StaticResource SettingTemplateSelector}">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="0" />
                    </ItemsRepeater.Layout>
                </ItemsRepeater>
            </StackPanel>
        </DataTemplate>
    </Page.Resources>

    <Grid Padding="24,8,24,24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Page header -->
        <TextBlock
            Grid.Row="0"
            Text="显示器设置"
            Style="{StaticResource TitleLargeTextBlockStyle}"
            Margin="0,0,0,12" />

        <!-- Status bar -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ProgressRing
                Grid.Column="0"
                Width="16" Height="16"
                IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                Margin="0,0,8,0"
                VerticalAlignment="Center" />

            <TextBlock
                Grid.Column="1"
                Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                Style="{StaticResource BodyTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                VerticalAlignment="Center"
                TextTrimming="CharacterEllipsis" />

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                <Button
                    Command="{x:Bind ViewModel.RefreshAllCommand}"
                    IsEnabled="{x:Bind ViewModel.IsConnected, Mode=OneWay}"
                    Style="{StaticResource SubtleButtonStyle}"
                    Padding="12,4"
                    AutomationProperties.Name="刷新全部设置">
                    <FontIcon Glyph="&#xE72C;" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                </Button>
                <Button
                    x:Name="SettingsButton"
                    Click="OnSettingsClick"
                    Style="{StaticResource SubtleButtonStyle}"
                    Padding="12,4"
                    AutomationProperties.Name="打开应用设置">
                    <FontIcon Glyph="&#xE713;" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- Settings content -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <Grid>
                <ItemsRepeater
                    x:Name="SettingsRepeater"
                    ItemsSource="{x:Bind ViewModel.Categories}"
                    ItemTemplate="{StaticResource CategoryTemplate}" />

                <!-- Loading overlay -->
                <ProgressRing
                    x:Name="LoadingOverlay"
                    IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                    Width="48" Height="48"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="0,48,0,0" />
            </Grid>
        </ScrollViewer>

        <!-- Bottom status text -->
        <TextBlock
            Grid.Row="3"
            Style="{StaticResource CaptionTextBlockStyle}"
            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
            Text="关闭窗口将最小化到系统托盘  |  右键托盘图标可关闭所有进程"
            HorizontalAlignment="Right"
            Margin="0,12,0,0" />
    </Grid>
</Page>
