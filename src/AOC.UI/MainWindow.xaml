<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="aoc.UI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:aoc.UI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="AOC.UI"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="AppTitleBar" Title="AOC.UI">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <!-- Pin / always-on-top toggle button (overlays title bar, right side) -->
        <Button
            x:Name="PinButton"
            Grid.Row="0"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Margin="0,0,152,0"
            Padding="8,4"
            MinWidth="32"
            MinHeight="28"
            Style="{StaticResource SubtleButtonStyle}"
            Click="OnPinButtonClick"
            ToolTipService.ToolTip="窗口置顶"
            AutomationProperties.Name="窗口置顶切换">
            <FontIcon x:Name="PinIcon" Glyph="&#xE718;" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
        </Button>

        <Frame x:Name="RootFrame" Grid.Row="1" />

        <!-- Theme-transition reveal overlay (covers full window) -->
        <Grid x:Name="ThemeOverlay"
              Grid.RowSpan="2"
              IsHitTestVisible="False">
            <Rectangle x:Name="RevealCircle"
                       Width="16" Height="16"
                       RadiusX="8" RadiusY="8"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top"
                       RenderTransformOrigin="0.5,0.5">
                <Rectangle.Fill>
                    <SolidColorBrush x:Name="RevealBrush" Color="Transparent" />
                </Rectangle.Fill>
                <Rectangle.RenderTransform>
                    <CompositeTransform x:Name="RevealTransform"
                                        ScaleX="0" ScaleY="0" />
                </Rectangle.RenderTransform>
            </Rectangle>
        </Grid>
    </Grid>
</Window>
